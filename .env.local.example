# -----------------------------------------------------------------------------
# Raffu — environment variables
# Copy to .env.local for local dev. Configure in Vercel for production.
# -----------------------------------------------------------------------------

# Supabase — from your Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only — for admin operations from server actions
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resend — from resend.com → API Keys
RESEND_API_KEY=re_YOUR_KEY
# Must be a verified sender at resend.com (verify the raffu.xyz domain first)
RESEND_FROM_EMAIL="Raffu <hello@raffu.xyz>"

# Public URL — used in email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: NEXT_PUBLIC_APP_URL=https://raffu.xyz
